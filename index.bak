<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Radio Master Library Tool</title>
    <style>
        body { font-family: sans-serif; max-width: 800px; margin: 20px auto; line-height: 1.6; padding: 20px; background: #f4f4f9; }
        .box { background: white; padding: 30px; border-radius: 8px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); border-top: 5px solid #3498db; }
        .status { font-size: 0.9em; color: #7f8c8d; margin-bottom: 20px; padding: 10px; background: #ebf5fb; border-radius: 4px; }
        h2 { color: #2c3e50; margin-top: 0; }
        button { background: #27ae60; color: white; border: none; padding: 12px 24px; border-radius: 4px; cursor: pointer; font-size: 1em; font-weight: bold; transition: 0.2s; }
        button:hover { background: #219150; transform: translateY(-1px); }
        button:disabled { background: #bdc3c7; cursor: not-allowed; }
        pre { background: #2c3e50; color: #ecf0f1; padding: 20px; overflow-x: auto; border-radius: 4px; font-size: 0.95em; white-space: pre-wrap; line-height: 1.4; }
        .download-btn { background: #3498db; margin-top: 15px; }
        .loader { display: inline-block; width: 12px; height: 12px; border: 2px solid #3498db; border-radius: 50%; border-top-color: transparent; animation: spin 1s linear infinite; margin-right: 8px; }
        @keyframes spin { to { transform: rotate(360deg); } }
    </style>
</head>
<body>
    <div class="box">
        <h2>Radio Master Library Tool</h2>
        <div class="status" id="loadStatus"><span class="loader"></span>Connecting to National Request Chart Database...</div>
        
        <button id="genBtn" onclick="generatePlaylist()" disabled>Generate 1-Hour Playlist</button>
        
        <div id="outputArea" style="display:none;">
            <h3>Generated Playlist</h3>
            <pre id="playlistDisplay"></pre>
            <button class="download-btn" onclick="downloadTxt()">Download PlayList.txt</button>
        </div>
    </div>

    <script>
        // YOUR DIRECT LIVE CSV LINK
        const SHEET_CSV_URL = 'https://docs.google.com/spreadsheets/d/e/2PACX-1vSZf2oqinMZWPB0z9dXTfbQxsuzssny4BV5-htEB-udb0quC7a0T8W-uXHbVcF8HycL4h_XBKveNVNm/pub?gid=984873385&single=true&output=csv';
        
        let libraryData = [];
        let generatedText = "";

        async function fetchLibrary() {
            try {
                const response = await fetch(SHEET_CSV_URL);
                if (!response.ok) throw new Error("Network response was not ok");
                const csvText = await response.text();
                
                // Parse CSV rows
                const lines = csvText.split(/\r?\n/);
                libraryData = lines.slice(1)
                    .map(line => line.split(','))
                    .filter(cols => cols.length >= 4 && cols[1] !== ""); // Ensure valid data
                
                document.getElementById('loadStatus').innerHTML = `<strong>Library Online:</strong> ${libraryData.length} songs synced. Ready to generate.`;
                document.getElementById('genBtn').disabled = false;
            } catch (err) {
                document.getElementById('loadStatus').innerHTML = "<span style='color:#e74c3c'><strong>Error:</strong> Could not load library data.</span>";
                console.error(err);
            }
        }

        function generatePlaylist() {
            const pattern = ["A", "B", "A", "C"]; // From rotation rules
            let playlist = [];
            let usedArtists = new Set(); // Artist Separation logic

            for (let slot = 1; slot <= 18; slot++) {
                let category = pattern[(slot - 1) % 4];
                
                // Filter pool: Matches Category AND Artist hasn't been used yet
                let pool = libraryData.filter(r => 
                    r[3] && r[3].trim().toUpperCase() === category && 
                    !usedArtists.has(r[1].trim())
                );
                
                if (pool.length > 0) {
                    let pick = pool[Math.floor(Math.random() * pool.length)];
                    playlist.push({
                        slot: slot,
                        artist: pick[1].trim(),
                        title: pick[2].trim(),
                        cat: category,
                        ty: pick[0].trim()
                    });
                    usedArtists.add(pick[1].trim());
                }
            }

            displayPlaylist(playlist);
        }

        function displayPlaylist(list) {
            generatedText = "--- RADIO PLAYLIST LOG ---\n";
            generatedText += "STATION: RUGBY HOSPITAL RADIO\n";
            generatedText += "PROJECT: ALL TIME FAVOURITES\n";
            generatedText += "--------------------------\n\n";

            list.forEach(s => {
                // Slots 1-14 STRICT, 15-18 OPTIONAL
                let status = s.slot <= 14 ? "[STRICT]  " : "[OPTIONAL]";
                generatedText += `${s.slot.toString().padStart(2, '0')}. ${status} [${s.cat}] ${s.artist} - ${s.title} (Chart Pos: #${s.ty})\n`;
            });

            document.getElementById('playlistDisplay').innerText = generatedText;
            document.getElementById('outputArea').style.display = 'block';
            window.scrollTo(0, document.body.scrollHeight);
        }

        function downloadTxt() {
            const element = document.createElement("a");
            const file = new Blob([generatedText], {type: 'text/plain'});
            element.href = URL.createObjectURL(file);
            element.download = "PlayList.txt";
            document.body.appendChild(element);
            element.click();
        }

        fetchLibrary();
    </script>
</body>
</html>
